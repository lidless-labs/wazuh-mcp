#!/bin/bash
# Single verification entrypoint. CI and AGENTS.md both defer to this file,
# so the gate lives in exactly one place.
# Tests are fully mocked; this never touches a live SIEM.
set -euo pipefail
cd "$(dirname "$0")/.."

npm test
npm run typecheck
npm run build
# npm run pack:check is conditional (only when the publish payload changes:
# dist, README.md, LICENSE, package.json). Run it manually for those changes.
