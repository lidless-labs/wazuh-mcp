{
  "name": "wazuh-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for the Wazuh SIEM/XDR platform",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wazuh-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "wazuh",
    "mcp",
    "siem",
    "xdr",
    "security",
    "model-context-protocol"
  ],
  "author": "Solomon Neas <me@solomonneas.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solomonneas/wazuh-mcp.git"
  },
  "homepage": "https://github.com/solomonneas/wazuh-mcp#readme",
  "bugs": {
    "url": "https://github.com/solomonneas/wazuh-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
