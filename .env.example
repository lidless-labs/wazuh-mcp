WAZUH_URL=https://localhost:55000
WAZUH_USERNAME=wazuh-wui
WAZUH_PASSWORD=wazuh-wui
# Set to true in production. false is for trusted self-signed lab environments.
WAZUH_VERIFY_SSL=false
WAZUH_TIMEOUT=30
WAZUH_MCP_MAX_RESPONSE_BYTES=250000

# Optional, required for alert tools and the wazuh://alerts/recent resource.
WAZUH_INDEXER_URL=https://localhost:9200
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=admin
# Set to true in production. false is for trusted self-signed lab environments.
WAZUH_INDEXER_VERIFY_SSL=false
WAZUH_INDEXER_TIMEOUT=30
